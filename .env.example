PYTHON_PATH=C:\Programming\Python\data
PORT=5000
NODE_ENV=development

# MongoDB (required for auth + daily challenges)
# Recommended: run `npm run db:setup` — saves split vars (password auto URL-encoded).
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>
# Or use a full URI instead (comment out the four vars above):
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/polycode?retryWrites=true&w=majority
# Use system DNS instead of 8.8.8.8/1.1.1.1 only if you fixed Windows DNS manually:
# MONGODB_DNS=system
# Optional auth settings
JWT_SECRET=add_your_jwt_secret_here
JWT_EXPIRES_IN=add_your_jwt_expires_in_here

# ----------------------------
# Google Drive — profile pictures
# PERSONAL GMAIL: use OAuth (service accounts have no storage on Gmail).
# Redirect URI in Google Cloud: http://localhost:3333/oauth2callback
# Run: node scripts/google-drive-oauth-setup.js
GOOGLE_DRIVE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=from_setup_script
GOOGLE_DRIVE_FOLDER_ID=folder_id_in_your_own_drive
# Optional: separate folder for PolyMentor prompt exports (defaults to GOOGLE_DRIVE_FOLDER_ID)
# GOOGLE_DRIVE_PROMPTS_FOLDER_ID=folder_id_for_prompt_exports
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=your_redirect_uri
# WORKSPACE ONLY: service account + Shared Drive (not personal Gmail)
# GOOGLE_DRIVE_CREDENTIALS_PATH=./secrets/google-service-account.json

# ----------------------------
# Groq — PolyMentor assistant (landing page chat)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
ASSISTANT_RATE_LIMIT_MAX=20

# Export PolyMentor prompts (MongoDB → Google Drive JSON)
#PROMPTS_EXPORT_SECRET=long_random_secret_for_api_and_cron
# GOOGLE_DRIVE_AUTO_EXPORT_PROMPTS=false

# ----------------------------
# PolyMentor ML — training + Pinecone RAG + custom model
# Export: npm run ml:export-training
# Pinecone: npm run ml:sync-pinecone
# Guide: docs/POLYMENTOR_MLOPS.md
#ASSISTANT_PROVIDER=groq
#ASSISTANT_PROVIDER=custom
#CUSTOM_MODEL_BASE_URL=https://your-finetuned-host/v1
#CUSTOM_MODEL_API_KEY=optional
#CUSTOM_MODEL_NAME=polymentor-finetuned
#PINECONE_API_KEY=your_pinecone_api_key
#PINECONE_INDEX_HOST=your-index-xxxx.svc.us-east-1.pinecone.io
#PINECONE_NAMESPACE=polymentor
#PINECONE_RAG_ENABLED=false
#OPENAI_API_KEY=your_openai_key_for_embeddings_only
#OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------
FRONTEND_URL=https://code.quantumlogicslimited.com
PROD_FRONTEND_URL=https://code.quantumlogicslimited.com
CORS_ORIGINS=https://code.quantumlogicslimited.com,https://www.code.quantumlogicslimited.com

# ----------------------------
# Optional settings for development
MAX_SCAN_DEPTH=add_your_max_scan_depth_here
INCLUDE_FILE_TYPES=add_your_include_file_types_here
EXCLUDE_DIRS=add_your_exclude_dirs_here
VERBOSE_LOGGING=add_your_verbose_logging_here